@using SixBeeHealthCare.Web.ViewModels
@model EditAppointmentViewModel
@{
    ViewData["Title"] = "Edit Appointment";
}

<div class="max-w-2xl mx-auto px-4 py-10">
    <div class="mb-6 flex items-center gap-3">
        <a asp-action="Index"
           class="text-gray-400 hover:text-gray-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
            </svg>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Edit Appointment</h1>
            <p class="text-sm text-gray-500">#@Model.Id</p>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <form asp-action="Edit" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly"
                 class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"></div>

            <!-- Name -->
            <div class="mb-5">
                <label asp-for="PatientName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="PatientName"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition" />
                <span asp-validation-for="PatientName" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Appointment Date & Time -->
            <div class="mb-5">
                <label asp-for="AppointmentDateTime" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="AppointmentDateTime"
                       type="datetime-local"
                       asp-format="{0:yyyy-MM-ddTHH:mm}"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition" />
                <span asp-validation-for="AppointmentDateTime" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Description -->
            <div class="mb-5">
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <textarea asp-for="Description"
                          rows="3"
                          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Contact Number -->
            <div class="mb-5">
                <label asp-for="ContactNumber" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="ContactNumber"
                       type="tel"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition" />
                <span asp-validation-for="ContactNumber" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Email -->
            <div class="mb-6">
                <label asp-for="EmailAddress" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="EmailAddress"
                       type="email"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition" />
                <span asp-validation-for="EmailAddress" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div class="flex items-center gap-3">
                <button type="submit"
                        class="bg-blue-700 hover:bg-blue-600 text-white font-semibold px-6 py-2.5 rounded-lg transition-colors shadow-sm">
                    Save Changes
                </button>
                <a asp-action="Index"
                   class="text-gray-500 hover:text-gray-700 font-medium px-4 py-2.5 rounded-lg transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

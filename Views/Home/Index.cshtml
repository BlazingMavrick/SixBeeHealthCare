@using SixBeeHealthCare.Web.ViewModels
@model BookingViewModel
@{
    ViewData["Title"] = "Book an Appointment";
}

<div class="max-w-2xl mx-auto px-4 py-10">
    <div class="mb-8 text-center">
        <h1 class="text-3xl font-bold text-gray-900">Book an Appointment</h1>
        <p class="mt-2 text-gray-500">Complete the form below and we'll confirm your appointment.</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <form asp-action="Index" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"></div>

            <!-- Name -->
            <div class="mb-5">
                <label asp-for="PatientName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="PatientName"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                       placeholder="e.g. Jane Smith" />
                <span asp-validation-for="PatientName" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Appointment Date & Time -->
            <div class="mb-5">
                <label asp-for="AppointmentDateTime" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="AppointmentDateTime"
                       type="datetime-local"
                       asp-format="{0:yyyy-MM-ddTHH:mm}"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition" />
                <span asp-validation-for="AppointmentDateTime" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Description -->
            <div class="mb-5">
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <textarea asp-for="Description"
                          rows="3"
                          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                          placeholder="Brief description of your reason for visiting..."></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Contact Number -->
            <div class="mb-5">
                <label asp-for="ContactNumber" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="ContactNumber"
                       type="tel"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                       placeholder="e.g. 07700 900000" />
                <span asp-validation-for="ContactNumber" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Email -->
            <div class="mb-6">
                <label asp-for="EmailAddress" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="EmailAddress"
                       type="email"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                       placeholder="e.g. jane@example.com" />
                <span asp-validation-for="EmailAddress" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <button type="submit"
                    class="w-full bg-blue-700 hover:bg-blue-600 text-white font-semibold py-2.5 rounded-lg transition-colors shadow-sm">
                Request Appointment
            </button>
        </form>
    </div>
</div>
